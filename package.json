{
  "name": "rnboilerplate",
  "main": "expo-router/entry",
  "version": "1.0.0",
  "expo": {
    "doctor": {
      "reactNativeDirectoryCheck": {
        "listUnknownPackages": false
      }
    }
  },
  "scripts": {
    "start": "expo start",
    "reset-project": "node ./scripts/reset-project.js",
    "android": "expo run:android",
    "ios": "expo run:ios",
    "web": "expo start --web",
    "test": "jest",
    "test:ci": "jest --ci --coverage --maxWorkers=2",
    "lint": "expo lint",
    "format": "prettier --write --cache .",
    "generate": "openapi-generator-cli generate -g typescript-axios -i ./docs/api-doc.json -o ./src/shared/apis -c ./openapi.json",
    "template": "openapi-generator-cli author template -g typescript-axios -o ./mustaches",
    "generate:api": "openapi-generator-cli generate -g typescript-axios -i ./docs/api-doc.json -o  ./src/shared/apis -t ./mustaches -c ./openapi.json --skip-validate-spec",
    "postinstall": "husky install"
  },
  "dependencies": {
    "@babel/runtime": "^7.26.0",
    "@expo/metro-runtime": "~5.0.4",
    "@expo/vector-icons": "^14.1.0",
    "@hookform/resolvers": "^5.2.1",
    "@openapitools/openapi-generator-cli": "^2.15.3",
    "@react-native-community/netinfo": "11.4.1",
    "@react-navigation/bottom-tabs": "^7.0.0",
    "@react-navigation/elements": "^2.2.0",
    "@react-navigation/native": "^7.0.0",
    "@testing-library/jest-native": "^5.4.3",
    "@testing-library/react-native": "^12.9.0",
    "axios": "^1.7.8",
    "dotenv": "^16.4.7",
    "expo": "~53.0.20",
    "expo-asset": "~11.1.7",
    "expo-blur": "~14.1.5",
    "expo-build-properties": "~0.14.8",
    "expo-constants": "~17.1.7",
    "expo-font": "~13.3.2",
    "expo-haptics": "~14.1.4",
    "expo-linking": "~7.1.7",
    "expo-router": "~5.1.4",
    "expo-splash-screen": "~0.30.10",
    "expo-status-bar": "~2.2.3",
    "expo-symbols": "~0.4.5",
    "expo-system-ui": "~5.0.10",
    "expo-updates": "~0.28.17",
    "expo-web-browser": "~14.2.0",
    "react": "^19.1.1",
    "react-dom": "^19.1.1experiments",
    "react-hook-form": "^7.62.0",
    "react-native": "^0.79.5",
    "react-native-error-boundary": "^1.2.7",
    "react-native-gesture-handler": "~2.24.0",
    "react-native-global-props": "^1.1.5",
    "react-native-keyboard-aware-scroll-view": "^0.9.5",
    "react-native-reanimated": "~3.17.5",
    "react-native-safe-area-context": "5.4.0",
    "react-native-screens": "~4.11.1",
    "react-native-svg": "^15.12.1",
    "react-native-vector-icons": "^10.3.0",
    "react-native-web": "~0.20.0",
    "react-native-webview": "13.13.5",
    "zod": "^4.0.17"
  },
  "devDependencies": {
    "@babel/core": "^7.25.2",
    "@types/jest": "^29.5.12",
    "@types/node": "^22.10.2",
    "@types/react": "^19.1.9",
    "@types/react-native-global-props": "^1.1.6",
    "@types/react-native-vector-icons": "^6.4.18",
    "@types/react-test-renderer": "^18.3.0",
    "babel-preset-expo": "^12.0.4",
    "eslint": "^8.57.0",
    "eslint-config-expo": "~8.0.1",
    "eslint-config-prettier": "^9.1.0",
    "eslint-plugin-prettier": "^5.2.1",
    "husky": "^9.1.7",
    "jest": "^29.2.1",
    "jest-expo": "~52.0.3",
    "lint-staged": "^15.3.0",
    "prettier": "^3.4.1",
    "react-native-svg-transformer": "^1.5.1",
    "react-test-renderer": "^19.1.0",
    "typescript": "^5.3.3"
  },
  "private": true,
  "lint-staged": {
    "*.{ts,tsx}": [
      "pnpm format"
    ]
  }
}
